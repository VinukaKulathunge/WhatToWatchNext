# =============================================================================
# Hybrid Movie Recommender — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.
# =============================================================================

# Your TMDB (The Movie Database) API key.
# Get one for free at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Path where ChromaDB will persist its vector index on disk.
CHROMA_PERSIST_PATH=./chroma_db

# Path where the pickled NetworkX graph will be saved/loaded.
GRAPH_PICKLE_PATH=./graph/movie_graph.pkl

# Path to the SQLite database used for caching TMDB responses.
SQLITE_DB_PATH=./data/movies.db

# Number of recommendations to return by default.
TOP_N_RESULTS=10

# Number of movies to fetch from TMDB during setup.
SETUP_MOVIE_COUNT=1000
